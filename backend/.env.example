# Copy to .env and fill in values.

# Secrets
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# App database (our own — playlists, sessions, auth, indexed tracks)
DATABASE_URL=sqlite:///./app.db

# Music library: the directory the app scans for audio files. Uploads land
# under this directory and are indexed automatically.
MUSIC_DIR=./music

# SFX library: a separate root for mode-bound soundboard files. Mode
# manifests refer to file paths relative to this directory.
SFX_LIBRARY_DIR=./sfx

# Mode bundles (EQ presets live under each mode)
MODES_DIR=../modes

# CORS / cookies
ALLOWED_ORIGINS=http://localhost:5173
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=

# Server
LOG_LEVEL=info
