# Copy to .env and fill in values. Everything has a workable dev default.

# App database (our own — playlists, sessions, auth, indexed tracks)
DATABASE_URL=sqlite:///./app.db

# Music library: the directory the app scans for audio files. Uploads land
# under this directory and are indexed automatically.
MUSIC_DIR=./music

# SFX library: a separate root for mode-bound soundboard files. Mode
# manifests refer to file paths relative to this directory.
SFX_LIBRARY_DIR=./sfx

# Mode bundles (EQ presets live under each mode)
MODES_DIR=../modes

# Read-only seed copied into MODES_DIR on first boot when that dir is empty
# (the Docker image sets this to /seeds/modes; unset = no seeding).
# MODES_SEED_DIR=

# Remembered-devices registry — a standalone JSON file (not app.db) holding
# saved devices + their output-by-default flag. Put it on the data volume.
# DEVICES_FILE=./devices.json

# Server-side end-of-track advancement. On in production; the test suite
# turns it off so timing-based advances can't race assertions.
# ADVANCER_ENABLED=true

# CORS / cookies
ALLOWED_ORIGINS=http://localhost:5173
# The session cookie is Secure by default (HTTPS-only). Set to false ONLY for a
# plain-HTTP deployment with no TLS anywhere — e.g. reaching the server by LAN
# IP over http. Local dev via the Vite proxy on http://localhost still works
# with the default (browsers treat localhost as a secure context).
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_DOMAIN=
# SESSION_COOKIE_NAME=music_session
# SESSION_TTL_DAYS=30

# Upload guard rails (per request). Defaults are generous; lower them if the
# data volume is small. MAX_UPLOAD_FILE_BYTES is bytes (default 1 GiB).
# MAX_UPLOAD_FILES=500
# MAX_UPLOAD_FILE_BYTES=1073741824

# Server
LOG_LEVEL=info
# Built SPA served at / (the Docker image sets /app/static; unset = API only).
# STATIC_DIR=
