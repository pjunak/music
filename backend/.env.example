# Copy to .env and fill in values.

# Secrets
SECRET_KEY=change-me-to-a-long-random-string-at-least-64-chars

# App database (our own — nicknames, playlists, sessions, auth)
DATABASE_URL=sqlite:///./app.db

# Beets library database (read-only). Point this at your Beets install.
# Run `beet config -p` to find yours.
BEETS_LIBRARY_DB=/home/you/.config/beets/library.db

# Content directories (absolute paths recommended in production)
INCOMING_DIR=./incoming
LIBRARY_DIR=./library
MODES_DIR=../modes
PRESETS_DIR=../presets

# CORS / cookies
ALLOWED_ORIGINS=http://localhost:5173
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=

# Server
LOG_LEVEL=info
